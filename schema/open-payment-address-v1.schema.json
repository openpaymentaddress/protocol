{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpaymentaddress.org/schema/opap-v1.json",
  "title": "Open Payment Address Protocol v1",
  "description": "Normative structural schema for an OPAP/1 Record.",
  "$comment": "An OPAP Record is the machine-readable JSON document behind one canonical HTTPS OPID. Implementations MUST also enforce URL canonicalisation, same-origin deterministic record discovery, transport and CORS requirements, duplicate-key rejection, exact id equality, origin-key proof verification, IBAN checksum, trusted asset-registry validation, asset-currency matching, duplicate payment-option targets, split-allocation share sum, unique split recipients and contract-state validation. The asset registry is client policy and is intentionally not embedded in an OPAP Record.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "revision",
    "issued_at",
    "expires_at",
    "payment"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "$ref": "#/$defs/opid",
      "description": "The canonical OPID represented by this OPAP Record."
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991,
      "description": "Strictly increasing publication counter for this exact OPID."
    },
    "issued_at": {
      "$ref": "#/$defs/utcSecond",
      "description": "UTC issue time authenticated by the exact-byte record proof."
    },
    "expires_at": {
      "$ref": "#/$defs/utcSecond",
      "description": "UTC publication-expiry time, which MUST be later than issued_at."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
    },
    "payment": {
      "oneOf": [
        { "$ref": "#/$defs/optionsPayment" },
        { "$ref": "#/$defs/delegatePayment" }
      ]
    },
    "extensions": {
      "type": "object",
      "maxProperties": 32,
      "propertyNames": {
        "$ref": "#/$defs/namespaceId"
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "utcSecond": {
      "type": "string",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    },
    "opid": {
      "type": "string",
      "description": "A canonical absolute HTTPS URL OPID. Resolvers additionally enforce the constrained hostname and path grammar.",
      "minLength": 10,
      "maxLength": 512,
      "pattern": "^https://[^/?#:]+/(?:[A-Za-z0-9._~/-]|%[0-9A-F]{2})*$"
    },
    "namespaceId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?/[a-z0-9](?:[a-z0-9._-]{0,62}[a-z0-9])?$"
    },
    "ethereumAddress": {
      "type": "string",
      "minLength": 42,
      "maxLength": 42,
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "chainId": {
      "type": "string",
      "maxLength": 40,
      "pattern": "^eip155:[1-9][0-9]*$"
    },
    "iban": {
      "type": "string",
      "minLength": 15,
      "maxLength": 34,
      "pattern": "^[A-Z]{2}[0-9]{2}[A-Z0-9]{11,30}$"
    },
    "currency": {
      "type": "string",
      "description": "Settlement currency as an uppercase ISO 4217 alphabetic code.",
      "minLength": 3,
      "maxLength": 3,
      "pattern": "^[A-Z]{3}$"
    },
    "optionsPayment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "options"],
      "properties": {
        "type": { "const": "options" },
        "options": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "$comment": "Payment Options are ordered from the receiver's strongest to weakest settlement preference. Implementations MUST reject duplicate recipient-affecting option targets.",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/sepaPaymentOption" },
              { "$ref": "#/$defs/erc20PaymentOption" },
              { "$ref": "#/$defs/splitPaymentOption" },
              { "$ref": "#/$defs/extensionPaymentOption" }
            ]
          }
        }
      }
    },
    "sepaPaymentOption": {
      "type": "object",
      "$comment": "A SEPA Payment Option.",
      "additionalProperties": false,
      "required": ["type", "currency", "name", "iban"],
      "properties": {
        "type": { "const": "sepa" },
        "currency": { "const": "EUR" },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
        },
        "iban": { "$ref": "#/$defs/iban" }
      }
    },
    "erc20PaymentOption": {
      "type": "object",
      "$comment": "An ERC-20 Payment Option. Asset identity is the exact chain + asset pair. symbol is an untrusted display hint. Execution requires an active entry in the payer's authenticated, version-pinned asset registry.",
      "additionalProperties": false,
      "required": ["type", "currency", "chain", "asset", "recipient"],
      "properties": {
        "type": { "const": "erc20" },
        "currency": { "$ref": "#/$defs/currency" },
        "chain": { "$ref": "#/$defs/chainId" },
        "asset": { "$ref": "#/$defs/ethereumAddress" },
        "recipient": { "$ref": "#/$defs/ethereumAddress" },
        "symbol": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
        }
      }
    },
    "extensionPaymentOption": {
      "type": "object",
      "$comment": "A namespaced extension Payment Option.",
      "additionalProperties": false,
      "required": ["type", "currency", "data"],
      "properties": {
        "type": {
          "$ref": "#/$defs/namespaceId"
        },
        "currency": { "$ref": "#/$defs/currency" },
        "data": {
          "type": "object"
        }
      }
    },
    "delegatePayment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "target"],
      "properties": {
        "type": { "const": "delegate" },
        "target": { "$ref": "#/$defs/opid" }
      }
    },
    "splitPaymentOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "currency", "execution", "allocations"],
      "properties": {
        "type": { "const": "split" },
        "currency": { "$ref": "#/$defs/currency" },
        "execution": { "$ref": "#/$defs/splitExecution" },
        "allocations": {
          "type": "array",
          "minItems": 2,
          "maxItems": 16,
          "uniqueItems": true,
          "$comment": "Allocation order is execution-significant. recipient addresses MUST additionally be unique case-insensitively and share_ppm MUST sum exactly to 1000000.",
          "items": { "$ref": "#/$defs/splitAllocation" }
        }
      }
    },
    "splitExecution": {
      "type": "object",
      "$comment": "Split-contract execution data. The exact chain + asset pair MUST be active in the payer's authenticated, version-pinned asset registry before execution.",
      "additionalProperties": false,
      "required": ["type", "adapter", "chain", "asset", "contract", "config_id"],
      "properties": {
        "type": { "const": "erc20-contract" },
        "adapter": {
          "$ref": "#/$defs/namespaceId"
        },
        "chain": { "$ref": "#/$defs/chainId" },
        "asset": { "$ref": "#/$defs/ethereumAddress" },
        "contract": { "$ref": "#/$defs/ethereumAddress" },
        "config_id": {
          "type": "string",
          "minLength": 66,
          "maxLength": 66,
          "pattern": "^0x[a-fA-F0-9]{64}$"
        }
      }
    },
    "splitAllocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recipient", "share_ppm"],
      "properties": {
        "recipient": { "$ref": "#/$defs/ethereumAddress" },
        "share_ppm": {
          "type": "integer",
          "minimum": 1,
          "maximum": 999999
        }
      }
    }
  }
}
